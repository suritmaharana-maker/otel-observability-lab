# OTel Observability Lab — Environment Variables
# Copy this to .env and fill in real values
# NEVER commit .env to git

# ── AWS ──────────────────────────────────────────────
AWS_REGION=us-east-2
AWS_ACCOUNT_ID=your-account-id-here

# ── EKS ──────────────────────────────────────────────
EKS_CLUSTER_NAME=otel-lab
EKS_NODE_TYPE=t3.xlarge
EKS_NODE_COUNT=3

# ── Bedrock ──────────────────────────────────────────
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_REGION=us-east-2

# ── Dash0 (Phase 2+) ─────────────────────────────────
DASH0_OTLP_ENDPOINT=ingress.us-east-2.aws.dash0.com:4317
DASH0_AUTH_TOKEN=your-dash0-auth-token-here

# ── Dynatrace (Phase 7+) ─────────────────────────────
DT_ENDPOINT=https://your-env-id.live.dynatrace.com/api/v2/otlp
DT_API_TOKEN=your-dynatrace-api-token-here
# Token requires scopes: openTelemetryTrace.ingest, metrics.ingest, logs.ingest

# ── Datadog (Phase 7+) ───────────────────────────────
DD_API_KEY=your-datadog-api-key-here
DD_SITE=datadoghq.com

# ── App config ───────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
